# Environment Configuration — copy to .env and fill in values.
# Render.com sets DATABASE_URL automatically from the linked database.

# Database (Render sets this automatically; use SQLite locally)
DATABASE_URL=sqlite:///./deepfake_shield.db

# Security — generate a strong random string for production
SECRET_KEY=change-me-to-a-long-random-secure-string

# CORS — comma-separated allowed origins (use * for development)
ALLOWED_ORIGINS=*

# Optional overrides
MAX_FILE_SIZE=104857600
LOG_LEVEL=INFO
ENABLE_METRICS=false
